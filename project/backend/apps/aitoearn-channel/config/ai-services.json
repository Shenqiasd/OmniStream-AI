{
  "services": {
    "openai": {
      "enabled": true,
      "apiKey": "${OPENAI_API_KEY}",
      "baseUrl": "https://api.openai.com/v1",
      "models": ["gpt-4", "gpt-3.5-turbo"]
    },
    "kling": {
      "enabled": true,
      "apiKey": "${KLING_API_KEY}",
      "baseUrl": "${KLING_BASE_URL}",
      "models": ["kling-v1"]
    },
    "volcengine": {
      "enabled": true,
      "apiKey": "${VOLCENGINE_API_KEY}",
      "baseUrl": "${VOLCENGINE_BASE_URL}",
      "models": ["doubao-pro"]
    }
  }
}
